---
import { getCollection, getEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Byline from "../components/Byline.astro";
import ScoreDisc from "../components/ScoreDisc.astro";
import InkHatch from "../components/InkHatch.astro";
import ArticleCard from "../components/ArticleCard.astro";
import LeaderboardRow from "../components/LeaderboardRow.astro";

const all = (await getCollection("articles", ({ data }) => !data.draft)).sort(
  (a, b) =>
    b.data.date.valueOf() - a.data.date.valueOf() ||
    b.data.score - a.data.score
);

const lead = all.find((a) => a.data.featured) ?? all[0];
const leadPersona = lead ? await getEntry("personas", lead.data.author) : null;
const recent = all.filter((a) => a.slug !== lead?.slug).slice(0, 6);
const leaderboard = [...all].sort((a, b) => b.data.score - a.data.score).slice(0, 5);

const leadDate = lead?.data.date.toLocaleDateString("en-US", {
  weekday: "long",
  month: "long",
  day: "numeric",
  year: "numeric",
});
---
<BaseLayout title="Dipshit">
  {lead && (
    <section class="lead container" aria-label="Today's dipshit">
      <p class="kicker lead-kicker">
        <span class="lead-badge">Today's Dipshit</span>
        <span class="lead-date">{leadDate}</span>
      </p>
      <div class="lead-grid">
        <div class="lead-text">
          <h1 class="lead-headline">{lead.data.headline}</h1>
          <p class="lead-deck">{lead.data.deck}</p>
          <div class="lead-meta">
            {leadPersona && <Byline persona={leadPersona} size={40} />}
            <ScoreDisc score={lead.data.score} size={72} label="FINAL" />
          </div>
          <p class="lead-cta">
            <a class="lead-readmore" href={`/articles/${lead.slug}/`}>
              Read the full breakdown →
            </a>
          </p>
        </div>
        <div class="lead-media">
          {lead.data.photo ? (
            <Image
              src={lead.data.photo}
              alt={lead.data.photoAlt ?? ""}
              class="lead-img"
              widths={[480, 800, 1200]}
              sizes="(min-width: 768px) 50vw, 100vw"
            />
          ) : (
            <InkHatch ratio="4 / 5" label="No photograph on file." sub="Editor's note" ariaHidden />
          )}
        </div>
      </div>
    </section>
  )}

  {recent.length > 0 && (
    <section class="recent container" id="archive" aria-label="Also recently dumb">
      <header class="section-head">
        <h2 class="section-title">Also recently dumb.</h2>
        <p class="section-sub">A rolling record of the merely sub-90 moments.</p>
      </header>
      <ul class="recent-grid">
        {recent.map((article) => (
          <li><ArticleCard article={article} /></li>
        ))}
      </ul>
      <p class="recent-cta">
        <a class="recent-archive-btn" href="/previously/">
          Read every dipshit moment we've filed →
        </a>
        <span class="meta recent-archive-count">{all.length} entries.</span>
      </p>
    </section>
  )}

  {leaderboard.length > 0 && (
    <section class="leaderboard container" id="leaderboard" aria-label="Stupid of the week">
      <header class="section-head">
        <h2 class="section-title">The stupid of the week.</h2>
        <p class="section-sub">Highest Stupid Scores of the last seven days.</p>
      </header>
      <div class="lb-list">
        {leaderboard.map((article, i) => (
          <LeaderboardRow
            rank={i + 1}
            score={article.data.score}
            headline={article.data.headline}
            date={article.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
            delta={i === 0 ? "NEW" : "—"}
            href={`/articles/${article.slug}/`}
          />
        ))}
      </div>
    </section>
  )}

  <section class="subscribe-stub container" id="subscribe" aria-label="Subscribe (coming soon)">
    <div class="ss-card">
      <p class="kicker ss-kicker">✶ Read free forever. ✶</p>
      <h2 class="ss-headline">Five dollars a month, <em>or none of this gets written.</em></h2>
      <p class="ss-body">
        The subscription goes live shortly. Members will weight the daily Stupid Score, get the
        full archive, the weekly podcast, and a printed yearbook in December. For now the whole
        publication reads free.
      </p>
      <p class="ss-meta meta">Coming soon · No email signup yet · No payment yet</p>
    </div>
  </section>
</BaseLayout>

<style>
  .lead {
    padding-top: 32px;
    padding-bottom: 32px;
  }
  .lead-kicker {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
  }
  .lead-badge {
    background: var(--yellow);
    color: var(--ink);
    border: 1px solid var(--ink);
    padding: 4px 8px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .lead-date {
    color: var(--ink-60);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .lead-grid {
    display: grid;
    grid-template-columns: 1.45fr 1fr;
    gap: 56px;
    align-items: start;
  }
  .lead-headline {
    font-size: clamp(40px, 7vw, 78px);
    font-weight: 900;
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: 0 0 18px;
  }
  .lead-deck {
    font-family: var(--font-head);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1.4;
    color: var(--ink);
    margin: 0 0 28px;
  }
  .lead-meta {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .lead-cta {
    margin: 0;
  }
  .lead-readmore {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 6px;
  }
  .lead-img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.05);
    border: 1px solid var(--ink);
  }

  .recent {
    padding-top: 32px;
    padding-bottom: 24px;
    border-top: 1px solid var(--ink);
  }
  .section-head {
    margin-bottom: 28px;
  }
  .section-title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0 0 6px;
  }
  .section-sub {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-60);
    margin: 0;
  }
  .recent-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px 32px;
  }
  .recent-cta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin: 32px 0 0;
    padding-top: 18px;
    border-top: 1px solid var(--ink);
    flex-wrap: wrap;
  }
  .recent-archive-btn {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    padding: 10px 16px;
    border: 1px solid var(--ink);
    background: var(--paper);
  }
  .recent-archive-btn:hover,
  .recent-archive-btn:focus-visible {
    background: var(--ink);
    color: var(--paper);
  }
  .recent-archive-count {
    color: var(--ink-60);
  }

  .leaderboard {
    padding-top: 48px;
    padding-bottom: 24px;
  }

  .subscribe-stub {
    padding-top: 48px;
    padding-bottom: 64px;
  }
  .ss-card {
    background: var(--paper2);
    border: 1px solid var(--ink);
    padding: 40px 48px;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .ss-kicker {
    color: var(--ink-60);
    margin-bottom: 14px;
  }
  .ss-headline {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: clamp(28px, 3.6vw, 42px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 18px;
  }
  .ss-headline em {
    font-style: italic;
    font-weight: 600;
  }
  .ss-body {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink);
    max-width: 60ch;
    margin: 0 auto 18px;
  }
  .ss-meta {
    color: var(--ink-40);
    margin: 0;
  }

  @media (max-width: 768px) {
    .lead-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .lead-headline {
      font-size: 34px;
    }
    .recent-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .ss-card {
      padding: 28px 22px;
    }
  }
</style>

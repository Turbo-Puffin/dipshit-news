---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const all = (await getCollection("articles", ({ data }) => !data.draft)).sort(
  (a, b) =>
    b.data.date.valueOf() - a.data.date.valueOf() ||
    b.data.score - a.data.score
);

const personaCache = new Map<string, { name: string; shortName: string }>();
for (const post of all) {
  if (!personaCache.has(post.data.author)) {
    const persona = await getEntry("personas", post.data.author);
    if (persona) {
      personaCache.set(post.data.author, {
        name: persona.data.name,
        shortName: persona.data.shortName,
      });
    }
  }
}

type Entry = (typeof all)[number];
const groupedByMonth: Array<{ key: string; label: string; entries: Entry[] }> = [];
const monthFmt = new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long" });
for (const entry of all) {
  const key = `${entry.data.date.getUTCFullYear()}-${String(entry.data.date.getUTCMonth() + 1).padStart(2, "0")}`;
  const label = monthFmt.format(entry.data.date);
  let bucket = groupedByMonth.find((b) => b.key === key);
  if (!bucket) {
    bucket = { key, label, entries: [] };
    groupedByMonth.push(bucket);
  }
  bucket.entries.push(entry);
}

const dayFmt = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", timeZone: "UTC" });
---
<BaseLayout title="Previously" description="The full archive of dipshit.news. Every day, sourced and scored, going back to August 2025.">
  <header class="container previously-head">
    <h1 class="previously-title">Previously.</h1>
    <p class="previously-deck">
      Every dipshit moment we've filed. Newest first. {all.length} entries and counting.
    </p>
  </header>

  <nav class="container previously-jumps" aria-label="Jump to month">
    {groupedByMonth.map((g) => (
      <a class="meta previously-jump" href={`#${g.key}`}>{g.label}.</a>
    ))}
  </nav>

  <section class="container previously-list">
    {groupedByMonth.map((g) => (
      <article class="previously-month" id={g.key}>
        <h2 class="previously-month-title">{g.label}.</h2>
        <ul class="previously-rows">
          {g.entries.map((entry) => {
            const author = personaCache.get(entry.data.author);
            return (
              <li class="previously-row">
                <a class="previously-link" href={`/articles/${entry.slug}/`}>
                  <span class="previously-date meta">{dayFmt(entry.data.date)}</span>
                  <span class="previously-score">
                    {entry.data.score}<span class="previously-of">/100</span>
                  </span>
                  <span class="previously-headline">{entry.data.headline}</span>
                  <span class="previously-author meta">{author ? author.shortName : entry.data.author}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .previously-head {
    padding-top: 32px;
    padding-bottom: 24px;
  }
  .previously-title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: clamp(48px, 7vw, 88px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }
  .previously-deck {
    font-family: var(--font-head);
    font-style: italic;
    font-size: clamp(18px, 1.6vw, 22px);
    color: var(--ink-60);
    margin: 0;
    max-width: 60ch;
  }

  .previously-jumps {
    padding-top: 12px;
    padding-bottom: 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px 22px;
    border-top: 1px solid var(--ink);
  }
  .previously-jump {
    color: var(--ink-60);
    text-decoration: none;
  }
  .previously-jump:hover,
  .previously-jump:focus-visible {
    color: var(--ink);
    text-decoration: underline;
  }

  .previously-list {
    padding-top: 0;
    padding-bottom: 32px;
  }
  .previously-month {
    border-top: 2px solid var(--ink);
    padding-top: 18px;
    margin-bottom: 32px;
  }
  .previously-month-title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0 0 14px;
  }

  .previously-rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .previously-row {
    border-top: 1px solid var(--ink-15);
  }
  .previously-row:first-child {
    border-top: 0;
  }
  .previously-link {
    display: grid;
    grid-template-columns: 80px 80px 1fr auto;
    gap: 16px;
    align-items: baseline;
    padding: 12px 0;
    text-decoration: none;
    color: var(--ink);
  }
  .previously-link:hover .previously-headline,
  .previously-link:focus-visible .previously-headline {
    text-decoration: underline;
  }
  .previously-date {
    color: var(--ink-60);
  }
  .previously-score {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 20px;
    letter-spacing: -0.01em;
  }
  .previously-of {
    font-size: 12px;
    color: var(--ink-40);
    margin-left: 2px;
  }
  .previously-headline {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 17px;
    line-height: 1.3;
  }
  .previously-author {
    color: var(--ink-60);
    text-align: right;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .previously-link {
      grid-template-columns: 60px 60px 1fr;
      gap: 10px;
    }
    .previously-author {
      grid-column: 1 / -1;
      text-align: left;
      padding-left: 70px;
      margin-top: -4px;
      font-size: 10px;
    }
    .previously-headline {
      font-size: 15px;
    }
  }
</style>

---
import { getCollection, getEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Byline from "../../components/Byline.astro";
import ScoreDisc from "../../components/ScoreDisc.astro";
import Rubric from "../../components/Rubric.astro";
import InkHatch from "../../components/InkHatch.astro";
import VoteWidget from "../../components/VoteWidget.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const persona = await getEntry("personas", article.data.author);
const { Content } = await article.render();
const dateFmt = article.data.date.toLocaleDateString("en-US", {
  weekday: "long",
  month: "long",
  day: "numeric",
  year: "numeric",
});
---
<BaseLayout
  title={article.data.headline}
  description={article.data.deck}
>
  <article class="article">
    <header class="container article-header">
      <p class="kicker article-kicker">
        <span class="article-cat">{article.data.category}.</span>
        <span class="article-date">{dateFmt}</span>
      </p>
      <h1 class="article-headline">{article.data.headline}</h1>
      <p class="article-deck">{article.data.deck}</p>
      <div class="article-meta">
        {persona && <Byline persona={persona} size={44} />}
        <ScoreDisc score={article.data.score} size={72} label="FINAL" />
      </div>
    </header>

    <div class="container article-media">
      {article.data.photo ? (
        <figure class="article-figure">
          <Image
            src={article.data.photo}
            alt={article.data.photoAlt ?? ""}
            class="article-img"
            widths={[480, 800, 1200, 1600]}
            sizes="(min-width: 768px) 1100px, 100vw"
          />
          {article.data.photoCaption && (
            <figcaption class="article-caption meta">
              {article.data.photoCaption}
            </figcaption>
          )}
        </figure>
      ) : (
        <InkHatch ratio="16 / 9" label="No photograph on file." sub="Editor's note" ariaHidden />
      )}
    </div>

    <div class="container article-body measure">
      <div class="article-prose">
        <Content />
      </div>

      {article.data.pull && (
        <blockquote class="article-pull">
          {article.data.pull}
        </blockquote>
      )}

      {article.data.rubric && (
        <Rubric items={article.data.rubric} total={article.data.score} />
      )}

      <VoteWidget articleId={article.slug} />

      <p class="article-source meta">
        Underlying fact —
        <a href={article.data.sourceUrl} rel="nofollow noopener" target="_blank">
          {article.data.sourcePublisher}
        </a>
      </p>

      {persona && (
        <aside class="article-bio">
          <h2 class="article-bio-title">About {persona.data.name}.</h2>
          <p class="article-bio-text">{persona.data.bio}</p>
          <p>
            <a class="meta article-bio-more" href={`/authors/${persona.slug}/`}>
              More by {persona.data.shortName} →
            </a>
          </p>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    padding-top: 32px;
  }
  .article-header {
    padding-top: 0;
    padding-bottom: 28px;
    max-width: 1080px;
  }
  .article-kicker {
    display: flex;
    gap: 14px;
    margin-bottom: 16px;
    color: var(--ink-60);
  }
  .article-cat {
    text-transform: capitalize;
  }
  .article-headline {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: clamp(36px, 6vw, 64px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin: 0 0 18px;
  }
  .article-deck {
    font-family: var(--font-head);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.4;
    color: var(--ink);
    margin: 0 0 26px;
    max-width: 60ch;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }

  .article-media {
    padding-top: 12px;
    padding-bottom: 12px;
  }
  .article-figure {
    margin: 0;
  }
  .article-img {
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 16 / 9;
    filter: grayscale(100%) contrast(1.05);
    border: 1px solid var(--ink);
  }
  .article-caption {
    margin-top: 8px;
    color: var(--ink-60);
  }

  .article-body {
    padding-top: 32px;
    padding-bottom: 32px;
  }
  .article-prose {
    font-family: var(--font-body);
    font-size: 20px;
    line-height: 1.65;
    color: var(--ink);
  }
  .article-prose :global(p) {
    margin: 0 0 1.2em;
  }
  .article-prose :global(p:first-of-type::first-letter) {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 88px;
    line-height: 0.85;
    float: left;
    padding: 4px 12px 0 0;
    color: var(--ink);
  }
  .article-prose :global(a) {
    text-decoration: underline;
  }
  .article-prose :global(em),
  .article-prose :global(i) {
    font-style: italic;
  }
  .article-prose :global(strong),
  .article-prose :global(b) {
    font-weight: 600;
  }
  .article-pull {
    font-family: var(--font-head);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(22px, 2.6vw, 32px);
    line-height: 1.3;
    color: var(--ink);
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
    padding: 24px 0;
    margin: 36px 0;
  }
  .article-source {
    margin: 16px 0 24px;
    color: var(--ink-60);
  }
  .article-source a {
    color: var(--ink);
  }

  .article-bio {
    background: var(--paper2);
    border-left: 3px solid var(--ink);
    padding: 22px 26px;
    margin-top: 40px;
  }
  .article-bio-title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 22px;
    margin: 0 0 8px;
  }
  .article-bio-text {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--ink);
    margin: 0 0 12px;
  }
  .article-bio-more {
    color: var(--ink);
  }

  @media (max-width: 768px) {
    .article-prose {
      font-size: 18px;
    }
    .article-prose :global(p:first-of-type::first-letter) {
      font-size: 56px;
    }
  }
</style>

---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const persona = await getEntry("personas", post.data.author);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="post-article">
    <h1>{post.data.title}</h1>
    <p class="post-meta">
      {formatDate(post.data.date)}
      {persona && (
        <>
          {" "}&middot; By <a href={`/authors/${persona.slug}/`}>{persona.data.name}</a>
        </>
      )}
    </p>
    <Content />
    {post.data.sourceUrl && (
      <p class="post-source">
        Underlying fact:{" "}
        <a href={post.data.sourceUrl} rel="nofollow noopener" target="_blank">
          {post.data.sourcePublisher ?? "source"}
        </a>
      </p>
    )}
    {persona && (
      <aside class="author-bio">
        <h3>About {persona.data.name}</h3>
        <p>{persona.data.bio}</p>
        <p><a href={`/authors/${persona.slug}/`}>More from {persona.data.name}</a></p>
      </aside>
    )}
  </article>
</BaseLayout>

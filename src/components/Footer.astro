---
import Logo from "./Logo.astro";

const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <Logo height={48} wordColor="var(--paper)" sunColor="var(--yellow)" ariaLabel="Dipshit" />
        <p class="footer-tag">A daily record of presidential dipshittery.</p>
      </div>
      <nav class="footer-col" aria-label="About">
        <h2 class="footer-title">About.</h2>
        <ul>
          <li><a href="/about/">Editorial mission</a></li>
          <li><a href="/staff/">Staff</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </nav>
      <nav class="footer-col" aria-label="Read">
        <h2 class="footer-title">Read.</h2>
        <ul>
          <li><a href="/">Today's lead</a></li>
          <li><a href="/previously/">Previously (archive)</a></li>
          <li><a href="/#leaderboard">Stupid of the week</a></li>
          <li><a href="/rss.xml">RSS</a></li>
        </ul>
      </nav>
      <nav class="footer-col" aria-label="Legal">
        <h2 class="footer-title">Legal.</h2>
        <ul>
          <li><a href="/privacy/">Privacy</a></li>
          <li><a href="/terms/">Terms</a></li>
        </ul>
      </nav>
    </div>
    <p class="footer-copy">
      © {year} Dipshit · Satire. Underlying facts cited; the editorial tone is the joke.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: var(--paper);
    padding: 56px 0 40px;
    margin-top: 80px;
  }
  .site-footer a {
    color: var(--paper);
    text-decoration: none;
  }
  .site-footer a:hover,
  .site-footer a:focus-visible {
    text-decoration: underline;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .footer-tag {
    font-family: var(--font-body);
    font-style: italic;
    color: var(--paper);
    opacity: 0.75;
    margin: 0;
    font-size: 14px;
  }
  .footer-title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 18px;
    margin: 0 0 12px;
    color: var(--paper);
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-col li {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.06em;
  }
  .footer-copy {
    margin: 48px 0 0;
    padding-top: 20px;
    border-top: 1px solid rgba(244, 240, 232, 0.2);
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--paper);
    opacity: 0.7;
  }
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }
</style>

---
interface Props {
  rank: number;
  score: number;
  headline: string;
  date: string;
  delta?: string;
  href: string;
}

const { rank, score, headline, date, delta = "—", href } = Astro.props;
---
<a class="lbrow" href={href}>
  <span class="lbrow-rank">{rank.toString().padStart(2, "0")}.</span>
  <span class="lbrow-score">{score}<span class="lbrow-of">/100</span></span>
  <span class="lbrow-headline">{headline}</span>
  <span class="lbrow-date">{date}</span>
  <span class="lbrow-delta">{delta}</span>
</a>

<style>
  .lbrow {
    display: grid;
    grid-template-columns: 40px 100px 1fr 80px 60px;
    gap: 16px;
    align-items: baseline;
    padding: 14px 0;
    border-top: 1px solid var(--ink-15);
    text-decoration: none;
    color: var(--ink);
  }
  .lbrow:first-of-type {
    border-top: 1px solid var(--ink);
  }
  .lbrow:hover .lbrow-headline,
  .lbrow:focus-visible .lbrow-headline {
    text-decoration: underline;
  }
  .lbrow-rank {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--ink-60);
  }
  .lbrow-score {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 22px;
    letter-spacing: -0.01em;
  }
  .lbrow-of {
    font-size: 13px;
    color: var(--ink-40);
    margin-left: 2px;
  }
  .lbrow-headline {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 18px;
    line-height: 1.3;
    color: var(--ink);
  }
  .lbrow-date,
  .lbrow-delta {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-40);
    text-align: right;
  }
  @media (max-width: 768px) {
    .lbrow {
      grid-template-columns: 32px 70px 1fr;
      gap: 12px;
    }
    .lbrow-date,
    .lbrow-delta {
      display: none;
    }
    .lbrow-headline {
      font-size: 15px;
    }
    .lbrow-score {
      font-size: 18px;
    }
  }
</style>
